# ============================================================
# FACTUS - SANDBOX (desarrollo/pruebas)
# Cambia FACTUS_ENV, FACTUS_API_URL y credenciales para producción.
# ============================================================
FACTUS_ENV=sandbox
FACTUS_API_URL=https://api-sandbox.factus.com.co

# Credenciales OAuth
FACTUS_USERNAME=
FACTUS_PASSWORD=
FACTUS_CLIENT_ID=
FACTUS_CLIENT_SECRET=

# Auth
FACTUS_AUTH_PATH=/oauth/token
FACTUS_REFRESH_TOKEN_PATH=/oauth/token

# Facturas
FACTUS_INVOICE_PATH=/v1/bills/validate
FACTUS_BILLS_LIST_PATH=/v1/bills
FACTUS_BILL_SHOW_PATH=/v1/bills/show/{number}
FACTUS_BILL_DOWNLOAD_PDF_PATH=/v1/bills/download-pdf/{number}
FACTUS_BILL_DOWNLOAD_XML_PATH=/v1/bills/download-xml/{number}
FACTUS_BILL_EMAIL_CONTENT_PATH=/v1/bills/{number}/email-content
FACTUS_BILL_SEND_EMAIL_PATH=/v1/bills/send-email/{number}
FACTUS_BILL_CUSTOM_PDF_UPLOAD_PATH=/v1/bills/custom-pdf/{number}
FACTUS_BILL_DELETE_BY_REFERENCE_PATH=/v1/bills/reference/{reference_code}

# Notas crédito
FACTUS_CREDIT_NOTE_PATH=/v1/credit-notes/validate
FACTUS_CREDIT_NOTES_LIST_PATH=/v1/credit-notes
FACTUS_CREDIT_NOTE_SHOW_PATH=/v1/credit-notes/show/{number}
FACTUS_CREDIT_NOTE_DOWNLOAD_PDF_PATH=/v1/credit-notes/download-pdf/{number}
FACTUS_CREDIT_NOTE_DOWNLOAD_XML_PATH=/v1/credit-notes/download-xml/{number}
FACTUS_CREDIT_NOTE_EMAIL_CONTENT_PATH=/v1/credit-notes/{number}/email-content
FACTUS_CREDIT_NOTE_SEND_EMAIL_PATH=/v1/credit-notes/send-email/{number}
FACTUS_CREDIT_NOTE_DELETE_BY_REFERENCE_PATH=/v1/credit-notes/reference/{reference_code}

# Documentos soporte
FACTUS_SUPPORT_DOCUMENT_VALIDATE_PATH=/v1/support-documents/validate
FACTUS_SUPPORT_DOCUMENTS_LIST_PATH=/v1/support-documents
FACTUS_SUPPORT_DOCUMENT_SHOW_PATH=/v1/support-documents/show/{number}
FACTUS_SUPPORT_DOCUMENT_DOWNLOAD_PDF_PATH=/v1/support-documents/download-pdf/{number}
FACTUS_SUPPORT_DOCUMENT_DOWNLOAD_XML_PATH=/v1/support-documents/download-xml/{number}
FACTUS_SUPPORT_DOCUMENT_DELETE_BY_REFERENCE_PATH=/v1/support-documents/reference/{reference_code}

# Notas de ajuste a documento soporte
FACTUS_SUPPORT_ADJUSTMENT_NOTE_VALIDATE_PATH=/v1/adjustment-notes/validate
FACTUS_SUPPORT_ADJUSTMENT_NOTES_LIST_PATH=/v1/adjustment-notes
FACTUS_SUPPORT_ADJUSTMENT_NOTE_SHOW_PATH=/v1/adjustment-notes/show/{number}
FACTUS_SUPPORT_ADJUSTMENT_NOTE_DOWNLOAD_PDF_PATH=/v1/adjustment-notes/download-pdf/{number}
FACTUS_SUPPORT_ADJUSTMENT_NOTE_DOWNLOAD_XML_PATH=/v1/adjustment-notes/download-xml/{number}
FACTUS_SUPPORT_ADJUSTMENT_NOTE_DELETE_BY_REFERENCE_PATH=/v1/adjustment-notes/reference/{reference_code}

# Rangos de numeración
FACTUS_NUMBERING_RANGES_PATH=/v1/numbering-ranges
FACTUS_NUMBERING_RANGE_SHOW_PATH=/v1/numbering-ranges/{id}
FACTUS_NUMBERING_RANGE_CREATE_PATH=/v1/numbering-ranges
FACTUS_NUMBERING_RANGE_DELETE_PATH=/v1/numbering-ranges/{id}
FACTUS_NUMBERING_RANGE_UPDATE_PATH=/v1/numbering-ranges/{id}/update-number
FACTUS_NUMBERING_RANGES_DIAN_PATH=/v1/numbering-ranges/dian

# Empresa / catálogos
FACTUS_COMPANY_SHOW_PATH=/v1/company
FACTUS_COMPANY_UPDATE_PATH=/v1/company
FACTUS_COMPANY_UPDATE_LOGO_PATH=/v1/company/update-image
FACTUS_TRIBUTES_PATH=/v1/tributes/products
FACTUS_MEASUREMENT_UNITS_PATH=/v1/measurement-units
FACTUS_COUNTRIES_PATH=/v1/countries
FACTUS_MUNICIPALITIES_PATH=/v1/municipalities
FACTUS_REFERENCE_TABLES_PATH=/v1/reference-tables
FACTUS_CUSTOMERS_LOOKUP_PATH=/v1/customers

# Extras ya soportados por el cliente
FACTUS_BILL_EVENTS_PATH=/v1/bills/events/{number}
FACTUS_BILL_TACIT_ACCEPTANCE_PATH=/v1/bills/acceptance-tacit/{number}
FACTUS_BILL_EMAIL_TEMPLATE_PATH=/v1/bills/email-template/{number}
FACTUS_DOCUMENT_RECEPTIONS_PATH=/v1/document-receptions
FACTUS_SUBSCRIPTIONS_PATH=/v1/subscriptions

# ============================================================
# FACTUS - PRODUCCIÓN
# Copia este bloque sobre las variables anteriores al desplegar.
# ============================================================
# FACTUS_ENV=production
# FACTUS_API_URL=https://api.factus.com.co
# FACTUS_USERNAME=
# FACTUS_PASSWORD=
# FACTUS_CLIENT_ID=
# FACTUS_CLIENT_SECRET=
